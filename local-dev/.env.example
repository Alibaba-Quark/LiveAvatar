# Copy this file to ".env" (same folder) and fill in your real key.
# .env is gitignored, so your key stays local and is never committed.
#
#   cp local-dev/.env.example local-dev/.env
#   # then edit local-dev/.env and paste your key

# Required: your OpenAI key with Realtime API access.
OPENAI_API_KEY=sk-your-key-here

# Optional: avatar mode. "mock" (default) for local testing, "runpod" when live.
AVATAR_MODE=mock
# RUNPOD_URL=https://your-runpod-endpoint
